# ─── ELEVENLABS ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...       # ID de la voz (ver README para elegir una en español)

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=https://tu-dominio.ngrok.io   # URL pública accesible desde Twilio

# ─── NEGOCIO ──────────────────────────────────────────────────────────────────
COMPANY_NAME=Financiera Sur
